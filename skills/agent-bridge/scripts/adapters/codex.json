{
  "bin": "codex",
  "stream_format": "codex-jsonl",
  "sid_key": "thread_id",
  "effort_map": { "low": "low", "medium": "medium", "high": "high", "xhigh": "xhigh", "max": "xhigh" },
  "model_map": { "top": "gpt-5.6-sol", "sol": "gpt-5.6-sol", "terra": "gpt-5.6-terra", "luna": "gpt-5.6-luna" },
  "model_args": ["-m", "{model}"],
  "cmd_new": [
    "exec",
    "-c", "model_reasoning_effort={effort}",
    "{model_args}",
    "--json",
    "--sandbox", "danger-full-access",
    "--skip-git-repo-check",
    "{prompt}"
  ],
  "cmd_resume": [
    "exec",
    "-c", "model_reasoning_effort={effort}",
    "{model_args}",
    "--json",
    "--sandbox", "danger-full-access",
    "--skip-git-repo-check",
    "resume", "{sid}",
    "{prompt}"
  ]
}
